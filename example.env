DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=ota_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional: set a non-empty value to enable API key protection on OTA endpoints
API_KEY=

# Optional: MinIO / S3-compatible media storage
# Set MINIO_ENABLED=True and provide these values to store APKs in object storage instead of local disk.
MINIO_ENABLED=True
MINIO_ENDPOINT_URL=http://minio:9000
MEDIA_PUBLIC_BASE_URL=http://localhost:9000
MINIO_BUCKET_NAME=ota-media
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION_NAME=us-east-1
MINIO_USE_SSL=False

# MinIO server root credentials (used by the minio container)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
