# --- App (Django) ---------------------------------------------------------
# Environment variables used by the `app` service (Django)
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: set a non-empty value to enable API key protection on OTA endpoints
API_KEY=

# --- Database (Postgres) -------------------------------------------------
# Environment variables used by the `db` service (Postgres)
POSTGRES_DB=ota_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- MinIO / S3-compatible storage (app) ---------------------------------
# Environment variables used by the `app` service to connect to MinIO/S3.
# These are read by Django (`config/settings.py`) when using object storage.
MINIO_ENDPOINT_URL=http://minio:9000
MEDIA_PUBLIC_BASE_URL=http://localhost:9000
MINIO_BUCKET_NAME=ota-media
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION_NAME=us-east-1
MINIO_USE_SSL=False

# --- MinIO server credentials (docker container) -------------------------
# These are used by the `minio` container in docker-compose (MINIO_ROOT_*).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
